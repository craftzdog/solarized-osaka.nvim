# solarized-osaka colors for dunst
# For more configuraion options see https://github.com/dunst-project/dunst/blob/master/dunstrc

[urgency_low]
    background = "#fdf5e2"
    foreground = "#576d74"
    frame_color = "#576d74"

[urgency_normal]
    background = "#fdf5e2"
    foreground = "#576d74"
    frame_color = "#576d74"

[urgency_critical]
    background = "#ede7d3"
    foreground = "#db302d"
    frame_color = "#db302d"
